# postgresql (docker, проброшен на localhost:5433)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/skill_dev

# redis (docker, проброшен на localhost:6379)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# хэширование/шифрование
JWT_SECRET_KEY=
GITHUB_TOKEN_ENCRYPTION_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/github/callback
GITHUB_FRONTEND_REDIRECT_URL=http://localhost:5173/profile/credentials

# логи
DEFAULT_LOGGER_LEVEL=DEBUG

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# запись администратора
ADMIN_EMAIL=admin@it-skill-dev.ru
ADMIN_PASSWORD=12345

# публичные URL
PUBLIC_SITE_URL=https://it-skill-dev.ru
FRONTEND_BASE_URL=http://localhost:5173

# почта (SMTP Beget)
MAIL_SMTP_HOST=smtp.beget.com
MAIL_SMTP_PORT=465
MAIL_SMTP_USERNAME=support@it-skill-dev.ru
MAIL_SMTP_PASSWORD=
MAIL_FROM_EMAIL=support@it-skill-dev.ru
MAIL_FROM_NAME=IT Skill Dev
MAIL_SMTP_USE_SSL=true
MAIL_SMTP_STARTTLS=false
MAIL_LOGO_PATH=backend/src/assets/mail-logo.png
MAIL_CODE_TTL_SECONDS=3600
MAIL_PASSWORD_CHANGE_RATE_LIMIT_SECONDS=60
