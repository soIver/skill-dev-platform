# Значения DATABASE_URL, REDIS_URL, CELERY_BROKER_URL и CELERY_RESULT_BACKEND
# в production задаёт docker-compose.prod.yml через внутренние имена сервисов.

# хэширование/шифрование
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
STRING_ENCRYPTION_ALGORITHM=fernet
STRING_ENCRYPTION_SECRET=change-me-to-a-random-string-at-least-32-chars

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://api.it-skill-dev.ru/github/callback
GITHUB_FRONTEND_REDIRECT_PATH=/account/credentials

# логи
DEFAULT_LOGGER_LEVEL=INFO

# приложение
API_ROUTE_PREFIX=/

# CORS
ALLOWED_ORIGINS=https://it-skill-dev.ru

# запись администратора
ADMIN_EMAIL=admin@it-skill-dev.ru
ADMIN_PASSWORD=change-me-to-a-strong-admin-password

# публичные URL
FRONTEND_BASE_URL=https://it-skill-dev.ru

# HeadHunter
HH_CLIENT_ID=
HH_CLIENT_SECRET=

# AI
OPENROUTER_API_KEY=

# почта (SMTP Beget)
MAIL_SMTP_HOST=smtp.beget.com
MAIL_SMTP_PORT=465
MAIL_SMTP_USERNAME=support@it-skill-dev.ru
MAIL_SMTP_PASSWORD=
MAIL_FROM_EMAIL=support@it-skill-dev.ru
MAIL_FROM_NAME=IT Skill Dev
MAIL_SMTP_USE_SSL=true
MAIL_SMTP_STARTTLS=false
MAIL_CODE_TTL_SECONDS=3600
MAIL_PASSWORD_CHANGE_RATE_LIMIT_SECONDS=60
