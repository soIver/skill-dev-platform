# postgresql (docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/skill_dev

# redis (docker)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# хэширование/шифрование
JWT_SECRET_KEY=
GITHUB_TOKEN_ENCRYPTION_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/github/callback
GITHUB_FRONTEND_REDIRECT_URL=http://localhost/profile/credentials

# логи
DEFAULT_LOGGER_LEVEL=DEBUG

# CORS
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# запись администратора
ADMIN_EMAIL=admin@it-skill-dev.ru
ADMIN_PASSWORD=12345
